<Window x:Class="CurrencyConvertor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Currency Convertor" 
        Height="400" 
        Width="500"
        MinHeight="350"
        MinWidth="450"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource PrimaryBackground}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Background="{DynamicResource HeaderBackground}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                <TextBlock Text="💱" FontSize="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Currency Convertor" 
                          FontSize="20" 
                          FontWeight="SemiBold" 
                          Foreground="{DynamicResource PrimaryText}"
                          VerticalAlignment="Center"/>
            </StackPanel>

            <ToggleButton x:Name="ThemeToggle" 
                         Content="🌙" 
                         FontSize="16"
                         Width="40" 
                         Height="30"
                         HorizontalAlignment="Right" 
                         Margin="0,0,20,0"
                         Click="ThemeToggle_Click"/>
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Amount Input -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="Amount" 
                          FontSize="14" 
                          Foreground="{DynamicResource SecondaryText}" 
                          Margin="0,0,0,5"/>
                <TextBox x:Name="AmountTextBox" 
                        FontSize="18" 
                        Height="45"
                        Background="{DynamicResource SecondaryBackground}"
                        Foreground="{DynamicResource PrimaryText}"
                        BorderBrush="{DynamicResource BorderColor}"
                        BorderThickness="1"
                        Padding="12,10"
                        Text="100"/>
            </StackPanel>

            <!-- Currency Selection -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- From Currency -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="From" 
                              FontSize="14" 
                              Foreground="{DynamicResource SecondaryText}" 
                              Margin="0,0,0,5"/>
                    <ComboBox x:Name="FromCurrencyComboBox" 
                             FontSize="16" 
                             Height="45"
                             Background="{DynamicResource SecondaryBackground}"
                             Foreground="{DynamicResource PrimaryText}"
                             BorderBrush="{DynamicResource BorderColor}"
                             IsEditable="True"
                             IsTextSearchEnabled="True"/>
                </StackPanel>

                <!-- Swap Button -->
                <Button x:Name="SwapButton" 
                       Grid.Column="1" 
                       Content="⇄" 
                       FontSize="18"
                       Width="40" 
                       Height="40"
                       Background="{DynamicResource SecondaryBackground}"
                       Foreground="{DynamicResource PrimaryText}"
                       BorderBrush="{DynamicResource BorderColor}"
                       Click="SwapButton_Click"
                       VerticalAlignment="Bottom"/>

                <!-- To Currency -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="To" 
                              FontSize="14" 
                              Foreground="{DynamicResource SecondaryText}" 
                              Margin="0,0,0,5"/>
                    <ComboBox x:Name="ToCurrencyComboBox" 
                             FontSize="16" 
                             Height="45"
                             Background="{DynamicResource SecondaryBackground}"
                             Foreground="{DynamicResource PrimaryText}"
                             BorderBrush="{DynamicResource BorderColor}"
                             IsEditable="True"
                             IsTextSearchEnabled="True"/>
                </StackPanel>
            </Grid>

            <!-- Convert Button -->
            <Button x:Name="ConvertButton" 
                   Grid.Row="4" 
                   Content="Convert" 
                   FontSize="16" 
                   Height="45"
                   Background="{DynamicResource AccentColor}"
                   Foreground="White"
                   BorderThickness="0"
                   FontWeight="SemiBold"
                   Click="ConvertButton_Click"/>

            <!-- Result -->
            <Border Grid.Row="6" 
                   Background="{DynamicResource SecondaryBackground}"
                   BorderBrush="{DynamicResource BorderColor}"
                   BorderThickness="1"
                   CornerRadius="4"
                   Padding="20"
                   MinHeight="60">
                <TextBlock x:Name="ResultTextBlock" 
                          Text="Enter amount and click Convert" 
                          FontSize="18" 
                          FontWeight="Medium"
                          Foreground="{DynamicResource PrimaryText}"
                          TextAlignment="Center"
                          TextWrapping="Wrap"/>
            </Border>

            <!-- Loading Indicator -->
            <ProgressBar x:Name="LoadingProgressBar" 
                        Grid.Row="8" 
                        Height="4" 
                        IsIndeterminate="True" 
                        Visibility="Collapsed"
                        Background="{DynamicResource SecondaryBackground}"
                        Foreground="{DynamicResource AccentColor}"/>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{DynamicResource StatusBarBackground}">
            <TextBlock x:Name="StatusTextBlock" 
                      Text="Ready" 
                      FontSize="12" 
                      Foreground="White"
                      Margin="10,5"
                      VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>